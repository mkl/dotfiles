# Managed by chezmoi - Starship prompt with Catppuccin Mocha palette

palette = "catppuccin_mocha"

format = """[](surface0)$os$username[](bg:blue fg:surface0)$directory[](bg:green fg:blue)$git_branch$git_status[](bg:teal fg:green)$hostname[](fg:teal) """

[os]
disabled = false
style = "bg:surface0 fg:text"

[os.symbols]
Ubuntu = " "
Linux = " "
Macos = " "

[username]
show_always = true
style_user = "bg:surface0 fg:text"
style_root = "bg:surface0 fg:red"
format = '[ $user]($style)'

[directory]
style = "bg:blue fg:crust bold"
format = "[ $path ]($style)"
truncation_length = 3
truncation_symbol = "…/"

[git_branch]
symbol = " "
style = "bg:green fg:crust"
format = '[ $symbol$branch ]($style)'

[git_status]
style = "bg:green fg:crust"
format = '[$all_status$ahead_behind ]($style)'

[hostname]
ssh_only = false
style = "bg:teal fg:crust"
format = '[ 󰒋 {{ .hostname }} ]($style)'

[palettes.catppuccin_mocha]
rosewater = "#f5e0dc"
flamingo = "#f2cdcd"
pink = "#f5c2e7"
mauve = "#cba6f7"
red = "#f38ba8"
